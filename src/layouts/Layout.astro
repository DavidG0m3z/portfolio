---
interface Props {
  title?: string;
}
const { title = "David Gómez · Backend Developer" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
      --bg:          #080B0F;
      --bg-card:     #0F1318;
      --bg-card2:    #161B22;
      --border:      #21262D;
      --text:        #F0F6FC;
      --text-muted:  #7D8590;
      --blue:        #58A6FF;
      --green:       #3FB950;
      --orange:      #F0A500;
      --accent:      #58A6FF;
      --purple:  #A371F7;  
      --cyan:    #39C5CF;  
      --pink:    #F778BA;  
      --yellow:  #E3B341;
      --neon:    #00FF9F;  
      --magenta: #FF00FF;  
      --volt:    #CCFF00;  
      --ice:     #00CFFF;  

  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    line-height: 1.6;
  }

  h1, h2, h3 {
    font-family: 'Space Grotesk', sans-serif;
  }
</style>
---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="inicio">
  <canvas id="code-bg"></canvas>

  <div class="container">
    <div class="hero-content">

      <div class="left">
        <p class="eyebrow">{t.hero.eyebrow}</p>

        <h1>
          {t.hero.title1}
          <span class="accent">{t.hero.title2}</span>
        </h1>

        <p class="description">{t.hero.description}</p>

        <div class="ctas">
          <a href="#proyectos" class="btn-primary">{t.hero.btnProjects}</a>
          <a href="#contacto" class="btn-secondary">{t.hero.btnContact}</a>
          <button class="btn-cv" id="open-cv-hero">{t.hero.btnCV}</button>
        </div>

        <div class="metrics">
          {t.hero.metrics.map(m => (
            <div class="metric">
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="right">
        <div class="photo-wrapper">
          <div class="photo-terminal">
            <div class="terminal-bar">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
              <span class="terminal-title">{t.hero.terminalTitle}</span>
            </div>
            <div class="photo-container">
              <img src="/foto-portfolio.jpg" alt="David Gómez" />
            </div>
          </div>
          <div class="tech-tags">
            <span>{t.hero.tags.location}</span>
            <span class="tag-available">{t.hero.tags.available}</span>
            <span class="tag-remote">{t.hero.tags.remote}</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const canvas = document.getElementById('code-bg');
    const ctx = canvas.getContext('2d');

    const code = [
      'package com.pagoya.wallet.transaction;',
      '',
      'import org.springframework.stereotype.Service;',
      'import org.springframework.transaction.annotation.Transactional;',
      'import lombok.RequiredArgsConstructor;',
      'import java.math.BigDecimal;',
      'import java.time.LocalDateTime;',
      '',
      '@Service',
      '@RequiredArgsConstructor',
      'public class TransactionService {',
      '',
      '    private final WalletRepository walletRepository;',
      '    private final TransactionRepository transactionRepository;',
      '    private final NotificationService notificationService;',
      '',
      '    @Transactional',
      '    public TransactionResponse transfer(TransferRequest request) {',
      '        Wallet origin = walletRepository',
      '            .findById(request.getOriginId())',
      '            .orElseThrow(() -> new WalletNotFoundException("Origin wallet not found"));',
      '',
      '        Wallet destination = walletRepository',
      '            .findById(request.getDestinationId())',
      '            .orElseThrow(() -> new WalletNotFoundException("Destination wallet not found"));',
      '',
      '        if (origin.getBalance().compareTo(request.getAmount()) < 0) {',
      '            throw new InsufficientFundsException("Insufficient balance");',
      '        }',
      '',
      '        origin.setBalance(origin.getBalance().subtract(request.getAmount()));',
      '        destination.setBalance(destination.getBalance().add(request.getAmount()));',
      '',
      '        Transaction tx = Transaction.builder()',
      '            .originWallet(origin)',
      '            .destinationWallet(destination)',
      '            .amount(request.getAmount())',
      '            .status(TransactionStatus.COMPLETED)',
      '            .createdAt(LocalDateTime.now())',
      '            .build();',
      '',
      '        transactionRepository.save(tx);',
      '        walletRepository.save(origin);',
      '        walletRepository.save(destination);',
      '',
      '        notificationService.notify(origin.getUser(), "Transfer sent: $" + request.getAmount());',
      '        notificationService.notify(destination.getUser(), "Transfer received: $" + request.getAmount());',
      '',
      '        return TransactionResponse.from(tx);',
      '    }',
      '',
      '    public Page<Transaction> getHistory(Long walletId, Pageable pageable) {',
      '        return transactionRepository.findByWalletId(walletId, pageable);',
      '    }',
      '',
      '    @Transactional',
      '    public void revert(Long transactionId) {',
      '        Transaction tx = transactionRepository',
      '            .findById(transactionId)',
      '            .orElseThrow(() -> new TransactionNotFoundException("Transaction not found"));',
      '',
      '        if (tx.getStatus() == TransactionStatus.REVERTED) {',
      '            throw new IllegalStateException("Transaction already reverted");',
      '        }',
      '',
      '        origin.setBalance(origin.getBalance().add(tx.getAmount()));',
      '        destination.setBalance(destination.getBalance().subtract(tx.getAmount()));',
      '',
      '        tx.setStatus(TransactionStatus.REVERTED);',
      '        tx.setRevertedAt(LocalDateTime.now());',
      '',
      '        transactionRepository.save(tx);',
      '        walletRepository.save(origin);',
      '        walletRepository.save(destination);',
      '    }',
      '}',
    ];

    const LINE_HEIGHT = 22;
    const FONT_SIZE   = 13;
    const SPEED       = 0.4;
    const PADDING     = 60;

    let y = 0;
    const totalHeight = code.length * LINE_HEIGHT;

    function resize() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.font = FONT_SIZE + 'px "JetBrains Mono", monospace';

      const startLine = Math.floor(y / LINE_HEIGHT);
      const visibleLines = Math.ceil(canvas.height / LINE_HEIGHT) + 2;

      for (let i = 0; i < visibleLines; i++) {
        const lineIndex = (startLine + i) % code.length;
        const lineY = PADDING + (i * LINE_HEIGHT) - (y % LINE_HEIGHT);
        const line = code[lineIndex];

        if (line.startsWith('//')) {
          ctx.fillStyle = 'rgba(100, 110, 120, 0.5)';
        } else if (line.startsWith('@')) {
          ctx.fillStyle = 'rgba(88, 166, 255, 0.2)';
        } else if (line.includes('public') || line.includes('private')) {
          ctx.fillStyle = 'rgba(120, 140, 160, 0.35)';
        } else if (line.trim() === '') {
          ctx.fillStyle = 'rgba(0,0,0,0)';
        } else {
          ctx.fillStyle = 'rgba(110, 125, 140, 0.3)';
        }

        ctx.fillText(line, PADDING, lineY);
      }

      y += SPEED;
      if (y > totalHeight) y = 0;
      requestAnimationFrame(draw);
    }

    resize();
    draw();
    window.addEventListener('resize', resize);

    // Botón Ver CV en Hero
    const btnHero = document.getElementById('open-cv-hero');
    if (btnHero) {
      btnHero.addEventListener('click', function () {
        document.getElementById('cv-modal').classList.add('open');
      });
    }
  });
</script>

<style>
  section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: var(--bg);
    overflow: hidden;
    padding-top: 60px;
  }

  canvas {
    position: absolute;
    inset: 0;
    opacity: 1;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem;
    width: 100%;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: center;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--blue);
    letter-spacing: 1px;
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  .accent { color: var(--blue); }

  .description {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .ctas {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--blue);
    color: #080B0F;
    font-weight: 600;
    padding: 0.7rem 1.6rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.7rem 1.6rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
    background: none;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
  }

  .btn-secondary:hover {
    border-color: var(--blue);
    color: var(--blue);
  }

  .btn-cv {
    background: none;
    border: 1px solid var(--green);
    color: var(--green);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.7rem 1.6rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .btn-cv:hover {
    background: var(--green);
    color: #080B0F;
  }

  .metrics {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .metric { display: flex; flex-direction: column; }

  .metric-value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--blue);
    line-height: 1;
  }

  .metric-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .photo-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .photo-terminal {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-card);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: var(--bg-card2);
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red    { background: #FF5F57; }
  .dot.yellow { background: #FEBC2E; }
  .dot.green  { background: #28C840; }

  .terminal-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }

  .photo-container {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .photo-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .tech-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tech-tags span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .tag-available {
    color: var(--green) !important;
    border-color: rgba(63, 185, 80, 0.4) !important;
  }

  .tag-remote {
    color: var(--blue) !important;
    border-color: rgba(88, 166, 255, 0.4) !important;
  }

  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .right {
      max-width: 320px;
      margin: 0 auto;
      width: 100%;
    }

    .metrics { gap: 1.5rem; }
  }

  @media (max-width: 480px) {
    h1 { font-size: 1.8rem; }

    .ctas { flex-direction: column; }

    .btn-primary,
    .btn-secondary,
    .btn-cv { text-align: center; }

    .metrics { gap: 1.25rem; }
    .metric-value { font-size: 1.4rem; }
  }
</style>
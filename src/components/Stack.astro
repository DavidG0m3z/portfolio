---
import {
  Code2, Server, Smartphone, Cloud, Database,
  Layout, TestTube, BarChart2, Cpu, Shield,
  GitBranch, Monitor, Layers, Workflow
} from '@lucide/astro';
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const groups = t.stack.groups.map((g, i) => ({
  ...g,
  icon: [Server, Smartphone, Layout, Cloud, Database, TestTube, BarChart2, BarChart2][i],
}));
const languages = t.stack.languages;

const specialtyIcons = [Code2, Monitor, Layers, Shield, Database, Smartphone, GitBranch, Cpu, Workflow];
---

<section id="stack">
  <div class="container">

    <div class="section-header">
      <p class="eyebrow">{t.stack.eyebrow}</p>
      <h2>{t.stack.title}</h2>
    </div>

    <div class="languages">
      {languages.map(lang => (
        <span class="lang-badge">{lang}</span>
      ))}
    </div>

    <div class="grid">
      {groups.map(group => (
        <div class="card">
          <div class="card-header">
            <span class="icon"><group.icon size={16} /></span>
            <h3>{group.category}</h3>
          </div>
          <ul>
            {group.items.map(item => (
              <li><span class="name">{item}</span></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="specialties-header">
      <p class="eyebrow">{t.stack.specialtiesEyebrow}</p>
      <h2>{t.stack.specialtiesTitle}</h2>
    </div>

    <div class="specialties">
      {t.stack.specialties.map((s, i) => (
        <div class="specialty">
          <span class="s-icon">
            {(() => {
              const Icon = specialtyIcons[i % specialtyIcons.length];
              return <Icon size={20} />;
            })()}
          </span>
          <div class="s-info">
            <span class="s-label">{s.label}</span>
            <span class="s-desc">{s.desc}</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
    background-color: var(--bg-card);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header,
  .specialties-header {
    margin-bottom: 2rem;
  }

  .specialties-header { margin-top: 4rem; }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--blue);
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
  }

  h2::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--blue);
    margin-top: 0.5rem;
  }

  .languages {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 3rem;
  }

  .lang-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    transition: border-color 0.2s, color 0.2s;
  }

  .lang-badge:hover {
    border-color: var(--blue);
    color: var(--blue);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .card:hover { border-color: var(--blue); }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .icon {
    color: var(--blue);
    display: flex;
    align-items: center;
  }

  h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  ul { list-style: none; }

  li {
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
  }

  li:last-child { border-bottom: none; }

  .name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .specialties {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .specialty {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s;
  }

  .specialty:hover { border-color: var(--blue); }

  .s-icon {
    color: var(--blue);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .s-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .s-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .s-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .grid,
    .specialties {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    section { padding: 4rem 1.25rem; }
    h2 { font-size: 1.6rem; }
    .grid,
    .specialties {
      grid-template-columns: 1fr;
    }
  }
</style>
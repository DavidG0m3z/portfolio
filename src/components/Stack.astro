---
import { 
  Code2, Server, Smartphone, Cloud, Database, 
  Layout, TestTube, BarChart2, Cpu, Shield,
  GitBranch, Monitor, Layers
} from 'lucide-astro';

const languages = ["Java", "TypeScript", "JavaScript", "C#", "Kotlin", "Python", "SQL"];

const groups = [
  {
    category: "Backend",
    icon: Server,
    items: [
      { name: "Spring Boot", level: 4 },
      { name: "NestJS", level: 4 },
      { name: "Express", level: 4 },
      { name: ".NET", level: 3 },
    ],
  },
  {
    category: "Mobile",
    icon: Smartphone,
    items: [
      { name: "React Native", level: 4 },
      { name: "Kotlin (Jetpack Compose)", level: 2 },
      { name: "Android", level: 1 },
    ],
  },
  {
    category: "Frontend",
    icon: Layout,
    items: [
      { name: "React", level: 3 },
      { name: "Astro", level: 2 },
    ],
  },
  {
    category: "Cloud & DevOps",
    icon: Cloud,
    items: [
      { name: "Docker", level: 3 },
      { name: "Kubernetes", level: 2 },
      { name: "GitHub Actions", level: 4 },
      { name: "AWS", level: 3 },
      { name: "Azure", level: 2 },
      { name: "Linux", level: 4 },
    ],
  },
  {
    category: "Bases de Datos",
    icon: Database,
    items: [
      { name: "PostgreSQL", level: 4 },
      { name: "MariaDB / MySQL", level: 4 },
      { name: "MongoDB", level: 3 },
      { name: "Redis", level: 2 },
      { name: "JPA / Hibernate", level: 4 },
      { name: "TypeORM", level: 4 },
    ],
  },
  {
    category: "Testing",
    icon: TestTube,
    items: [
      { name: "JUnit", level: 4 },
      { name: "Mockito", level: 4 },
      { name: "Jest", level: 4 },
      { name: "Vitest", level: 4 },
      { name: "SonarQube", level: 3 },
      { name: "Postman", level: 4 },
    ],
  },
  {
    category: "Data",
    icon: BarChart2,
    items: [
      { name: "Pandas", level: 3 },
      { name: "Matplotlib", level: 2 },
      { name: "Seaborn", level: 2 },
      { name: "Scikit-learn", level: 2 },
    ],
  },
  {
    category: "IA",
    icon: BarChart2,
    items: [
      { name: "Claude Code", level: 3 },
      { name: "GitHub Copilot", level: 2 },
      { name: "Open Code", level: 2 },
    ],
  },
];

const specialties = [
  { icon: Code2,     label: "REST APIs",         desc: "Diseño, versionado y documentación con Swagger" },
  { icon: Monitor,   label: "Cliente-Servidor",   desc: "HTTP, stateless, separación de responsabilidades" },
  { icon: Layers,    label: "Microservicios",     desc: "Spring Cloud, Gateway, Eureka, comunicación entre servicios" },
  { icon: Shield,    label: "Seguridad",          desc: "JWT, AWS IAM, autenticación y autorización" },
  { icon: Database,  label: "Diseño de BD",       desc: "Relacional, NoSQL, índices, maestro/esclavo" },
  { icon: Smartphone,label: "Apps Móviles",       desc: "React Native, Android nativo con Jetpack Compose" },
];
---

<section id="stack">
  <div class="container">

    <div class="section-header">
      <p class="eyebrow">// tech stack</p>
      <h2>Ecosistema Tecnológico</h2>
    </div>

    <!-- LENGUAJES -->
    <div class="languages">
      {languages.map(lang => (
        <span class="lang-badge">{lang}</span>
      ))}
    </div>

    <!-- GRUPOS -->
    <div class="grid">
      {groups.map(group => (
        <div class="card">
          <div class="card-header">
            <span class="icon"><group.icon size={16} /></span>
            <h3>{group.category}</h3>
          </div>
          <ul>
            {group.items.map(item => (
              <li>
                <span class="name">{item.name}</span>
                <span class="dots">
                  {[1,2,3,4,5].map(i => (
                    <span class={`dot ${i <= item.level ? 'active' : ''}`}></span>
                  ))}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- ESPECIALIDADES -->
    <div class="specialties-header">
      <p class="eyebrow">// specialties</p>
      <h2>Especialidades</h2>
    </div>

    <div class="specialties">
      {specialties.map(s => (
        <div class="specialty">
          <span class="s-icon"><s.icon size={20} /></span>
          <div class="s-info">
            <span class="s-label">{s.label}</span>
            <span class="s-desc">{s.desc}</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
    background-color: var(--bg-card);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header,
  .specialties-header {
    margin-bottom: 2rem;
  }

  .specialties-header {
    margin-top: 4rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--blue);
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
  }

  h2::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--blue);
    margin-top: 0.5rem;
  }

  /* LENGUAJES */
  .languages {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 3rem;
  }

  .lang-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    transition: border-color 0.2s, color 0.2s;
  }

  .lang-badge:hover {
    border-color: var(--blue);
    color: var(--blue);
  }

  /* GRID */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .card:hover { border-color: var(--blue); }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .icon {
    color: var(--blue);
    display: flex;
    align-items: center;
  }

  h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  ul { list-style: none; }

  li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
  }

  li:last-child { border-bottom: none; }

  .name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .dots {
    display: flex;
    gap: 4px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
  }

  .dot.active { background: var(--blue); }

  /* ESPECIALIDADES */
  .specialties {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .specialty {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s;
  }

  .specialty:hover { border-color: var(--blue); }

  .s-icon {
    color: var(--blue);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .s-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .s-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .s-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .grid,
    .specialties {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    section { padding: 4rem 1.25rem; }
    h2 { font-size: 1.6rem; }

    .grid,
    .specialties {
      grid-template-columns: 1fr;
    }
  }
</style>  
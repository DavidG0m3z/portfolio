---
const groups = [
  {
    category: "Java Backend",
    icon: "☕",
    items: [
      { name: "Java", level: 4 },
      { name: "Spring Boot", level: 4 },
      { name: "Spring Cloud", level: 3 },
      { name: "JPA / Hibernate", level: 3 },
      { name: "JUnit / Testing", level: 3 },
    ],
  },
  {
    category: "Cloud & DevOps",
    icon: "☁️",
    items: [
      { name: "Docker", level: 4 },
      { name: "GitHub Actions", level: 3 },
      { name: "AWS EKS", level: 2 },
      { name: "Linux", level: 4 },
      { name: "LocalStack", level: 2 },
    ],
  },
  {
    category: "Data Systems",
    icon: "🗄️",
    items: [
      { name: "PostgreSQL", level: 4 },
      { name: "MariaDB", level: 3 },
      { name: "TypeORM", level: 3 },
      { name: "Redis", level: 2 },
    ],
  },
  {
    category: "Mobile",
    icon: "📱",
    items: [
      { name: "Android", level: 3 },
      { name: "Jetpack Compose", level: 3 },
      { name: "Kotlin", level: 3 },
      { name: "Retrofit", level: 3 },
      { name: "WorkManager", level: 2 },
    ],
  },
  {
    category: "Frontend",
    icon: "🖥️",
    items: [
      { name: "React Native", level: 3 },
      { name: "TypeScript", level: 3 },
      { name: "Astro", level: 2 },
      { name: "NestJS", level: 3 },
    ],
  },
];

const specialties = [
  { icon: "⚡", label: "REST APIs" },
  { icon: "🔗", label: "Microservicios" },
  { icon: "🔐", label: "Seguridad JWT" },
  { icon: "📦", label: "Monolitos Modulares" },
];
---

<section id="stack">
  <div class="container">

    <div class="section-header">
      <p class="eyebrow">// tech stack</p>
      <h2>Ecosistema Tecnológico</h2>
    </div>

    <div class="grid">
      {groups.map(group => (
        <div class="card">
          <div class="card-header">
            <span class="icon">{group.icon}</span>
            <h3>{group.category}</h3>
          </div>
          <ul>
            {group.items.map(item => (
              <li>
                <span class="name">{item.name}</span>
                <span class="dots">
                  {[1,2,3,4,5].map(i => (
                    <span class={`dot ${i <= item.level ? 'active' : ''}`}></span>
                  ))}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="specialties">
      {specialties.map(s => (
        <div class="specialty">
          <span class="s-icon">{s.icon}</span>
          <span class="s-label">{s.label}</span>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
    background-color: var(--bg-card);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 3rem;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--blue);
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
  }

  h2::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--blue);
    margin-top: 0.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .card:hover { border-color: var(--blue); }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .icon { font-size: 1.1rem; }

  h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  ul { list-style: none; }

  li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--border);
  }

  li:last-child { border-bottom: none; }

  .name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .dots {
    display: flex;
    gap: 4px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
  }

  .dot.active { background: var(--blue); }

  /* SPECIALTIES */
  .specialties {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .specialty {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s;
  }

  .specialty:hover { border-color: var(--blue); }

  .s-icon { font-size: 1.3rem; }

  .s-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .specialties {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    section { padding: 4rem 1.25rem; }

    .grid {
      grid-template-columns: 1fr;
    }

    .specialties {
      grid-template-columns: repeat(2, 1fr);
    }

    h2 { font-size: 1.6rem; }
  }
</style>
---
import { Code, Database, GitBranch, Users, GraduationCap, BookOpen } from 'lucide-astro';

const facts = [
  {
    icon: GraduationCap,
    text: "Ingeniería de Sistemas, Universidad de Antioquia.",
  },
  {
    icon: Code,
    text: "Me obsesiona entender cómo los sistemas crecen, escalan y sobreviven al éxito.",
  },
  {
    icon: GitBranch,
    text: "Disfruto más diseñando diagramas de arquitectura que viendo Netflix",
  },
  {
    icon: Users,
    text: "Trabajo mejor en equipo, las mejores soluciones nacen del debate de ideas",
  },
  {
    icon: Database,
    text: "Creo que los datos son el activo más poderoso de cualquier negocio moderno",
  },
  {
    icon: BookOpen,
    text: "Siempre aprendiendo — actualmente: System Design, AWS y algoritmos",
  },
];
---

<section id="sobre-mi">
  <div class="container">
    <div class="grid">

      <div class="left">
        <p class="eyebrow">// about me</p>
        <h2>Sobre mí</h2>
        <p class="tagline">
          Desarrollador de software junior con mentalidad de senior.
        </p>
      </div>

      <div class="right">
        <ul>
          {facts.map(fact => (
            <li>
              <span class="icon">
                <fact.icon size={18} />
              </span>
              <span class="text">{fact.text}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--blue);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .tagline {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    border-left: 2px solid var(--blue);
    padding-left: 1rem;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  li {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 0.2s, transform 0.2s;
  }

  li:hover {
    border-color: var(--blue);
    transform: translateX(4px);
  }

  .icon {
    color: var(--blue);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .text {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    section { padding: 4rem 1.25rem; }
    h2 { font-size: 1.6rem; }
    .text { font-size: 0.85rem; }
  }
</style>
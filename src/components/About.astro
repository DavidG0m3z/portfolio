---
import { Code, Database, GitBranch, Users, GraduationCap, BookOpen, Brain } from '@lucide/astro';
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const icons = [Code, Database, GitBranch, Users, GraduationCap, BookOpen, Brain];
---

<section id="sobre-mi">
  <div class="container">
    <div class="grid">

      <div class="left">
        <p class="eyebrow">{t.about.eyebrow}</p>
        <h2>{t.about.title}</h2>
        <p class="tagline">{t.about.tagline}</p>
      </div>

      <div class="right">
        <ul>
          {t.about.facts.map((fact, i) => {
            const Icon = icons[i % icons.length];
            return (
              <li>
                <span class="icon"><Icon size={18} /></span>
                <span class="text">{fact}</span>
              </li>
            );
          })}
        </ul>
      </div>

    </div>
  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--blue);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .tagline {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    border-left: 2px solid var(--blue);
    padding-left: 1rem;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  li {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 0.2s, transform 0.2s;
  }

  li:hover {
    border-color: var(--blue);
    transform: translateX(4px);
  }

  .icon {
    color: var(--blue);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .text {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    section { padding: 4rem 1.25rem; }
    h2 { font-size: 1.6rem; }
    .text { font-size: 0.85rem; }
  }
</style>
---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
  lang: string;
}

const { t, lang } = Astro.props;
---

<header>
  <nav>
    <a href={lang === 'en' ? '/en' : '/'} class="logo">David Gómez_</a>

    <ul>
      {t.navbar.links.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>

    <div class="cv-buttons">
      <button class="btn-view" id="open-cv">{t.navbar.viewCV}</button>
    </div>

    <div class="lang-switch">
      <a href="/" class={lang === 'es' ? 'active' : ''}>ES</a>
      <span>|</span>
      <a href="/en" class={lang === 'en' ? 'active' : ''}>EN</a>
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <div class="mobile-menu" id="mobile-menu">
    {t.navbar.links.map(link => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
    <div class="mobile-bottom">
      <button class="btn-view" id="open-cv-mobile">{t.navbar.viewCV}</button>
      <div class="lang-switch-mobile">
        <a href="/" class={lang === 'es' ? 'active' : ''}>ES</a>
        <span>|</span>
        <a href="/en" class={lang === 'en' ? 'active' : ''}>EN</a>
      </div>
    </div>
  </div>
</header>

<!-- MODAL -->
<div class="modal-overlay" id="cv-modal">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">{t.navbar.cvModalTitle}</span>
      <div class="modal-actions">
        <a href={t.navbar.cvFile} download class="modal-download">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 16l-5-5h3V4h4v7h3l-5 5zm-7 4h14v-2H5v2z"/>
          </svg>
          {t.navbar.download}
        </a>
        <button class="modal-close" id="close-cv" aria-label="Cerrar">✕</button>
      </div>
    </div>
    <div class="modal-body">
      <object data={t.navbar.cvFile} type="application/pdf">
        <p><a href={t.navbar.cvFile} download>Descargar PDF</a></p>
      </object>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const modal      = document.getElementById('cv-modal');
    const openBtn    = document.getElementById('open-cv');
    const openMobile = document.getElementById('open-cv-mobile');
    const closeBtn   = document.getElementById('close-cv');
    const toggle     = document.getElementById('menu-toggle');
    const menu       = document.getElementById('mobile-menu');

    function openModal() { modal.classList.add('open'); }
    function closeModal() { modal.classList.remove('open'); }

    openBtn.addEventListener('click', openModal);
    if (openMobile) openMobile.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeModal();
    });

    toggle.addEventListener('click', function () {
      menu.classList.toggle('open');
      toggle.classList.toggle('open');
    });

    document.querySelectorAll('.mobile-link').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        toggle.classList.remove('open');
      });
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(8, 11, 15, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text);
    white-space: nowrap;
    flex-shrink: 0;
    text-decoration: none;
  }

  ul {
    display: flex;
    gap: 0.75rem;
    list-style: none;
  }

  a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.78rem;
    transition: color 0.2s;
  }

  a:hover { color: var(--blue); }

  .cv-buttons {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-shrink: 0;
  }

  .btn-view {
    background: none;
    color: var(--blue);
    border: 1px solid rgba(88, 166, 255, 0.4);
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-view:hover { background: rgba(88, 166, 255, 0.1); }

  /* LANG SWITCH */
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .lang-switch a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .lang-switch a.active {
    color: var(--blue);
    font-weight: 600;
  }

  .lang-switch span {
    color: var(--border);
    font-size: 0.7rem;
  }

  /* HAMBURGER */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .menu-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle.open span:nth-child(2) { opacity: 0; }
  .menu-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* MOBILE MENU */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--border);
    gap: 0.25rem;
  }

  .mobile-menu.open { display: flex; }

  .mobile-link {
    padding: 0.65rem 0;
    font-size: 0.95rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
  }

  .mobile-link:hover { color: var(--blue); }

  .mobile-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
  }

  .lang-switch-mobile {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .lang-switch-mobile a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .lang-switch-mobile a.active {
    color: var(--blue);
    font-weight: 600;
  }

  .lang-switch-mobile span { color: var(--border); }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 999;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--bg-card);
    border: 1px solid var(--border);
    width: 90%;
    max-width: 900px;
    height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 10px;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-card2);
    flex-shrink: 0;
  }

  .modal-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .modal-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .modal-download {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--blue);
    color: #080B0F;
    font-weight: 600;
    font-size: 0.78rem;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .modal-download:hover { opacity: 0.85; color: #080B0F; }

  .modal-close {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    width: 28px;
    height: 28px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
  }

  .modal-close:hover { border-color: var(--blue); color: var(--text); }

  .modal-body {
    position: relative;
    flex: 1;
    min-height: 0;
  }

  .modal-body object {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    ul { display: none; }
    .cv-buttons { display: none; }
    .lang-switch { display: none; }
    .menu-toggle { display: flex; }
  }

  @media (max-width: 768px) {
    .modal { width: 100%; height: 100vh; border-radius: 0; }
  }

  @media (max-width: 380px) {
    nav { padding: 0 1rem; }
  }
</style>
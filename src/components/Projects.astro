---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const projectsMeta = [
  {
    tags: ["NestJS", "TypeScript", "MariaDB", "TypeORM", "Scrum"],
    category: "backend",
    github: "https://github.com/DavidG0m3z/recursos-educativos-api-udea.git ",
    featured: true,
    status: "production",
  },
  {
    tags: ["NestJS", "TypeScript", "MariaDB", "YouTube API"],
    category: "backend",
    github: "https://github.com/DavidG0m3z/youtube-manager-api",
    featured: true,
    status: "production",
  },
  {
    tags: ["React Native", "Firebase", "TypeScript"],
    category: "mobile",
    github: "https://github.com/DavidG0m3z/bebio-app",
    featured: true,
    status: "production",
  },
  {
    tags: [".NET", "C#", "Clean Architecture", "REST"],
    category: "backend",
    github: "https://github.com/DavidG0m3z/task-manager-api",
    featured: false,
    status: "production",
  },
  {
    tags: ["Spring Boot", "Spring Cloud", "PostgreSQL", "Docker", "AWS EKS"],
    category: "backend",
    github: "https://github.com/DavidG0m3z/pagosya-backend",
    featured: false,
    status: "wip",
  },
  {
    tags: ["React Native", "TypeScript", "Spring Boot"],
    category: "mobile",
    github: "https://github.com/DavidG0m3z/pagosya-mobile",
    featured: false,
    status: "wip",
  },
];

const projects = t.projects.projects.map((p, i) => ({
  ...p,
  ...projectsMeta[i],
}));

const tabs = t.projects.tabs;
---

<section id="proyectos">
  <div class="container">

    <div class="section-header">
      <p class="eyebrow">{t.projects.eyebrow}</p>
      <h2>{t.projects.title}</h2>
    </div>

    <div class="tabs">
      {tabs.map((tab, i) => (
        <button class={`tab ${i === 0 ? 'active' : ''}`} data-tab={tab.toLowerCase()}>
          {tab}
        </button>
      ))}
    </div>

    <div class="grid" id="projects-grid">
      {projects.map(project => (
        <div
          class={`card ${project.featured ? 'featured' : ''}`}
          data-category={project.category}
          data-featured={project.featured}
        >
          <div class="card-top">
            <div class="card-meta">
              {project.status === 'wip' && (
                <span class="badge-wip">{t.projects.wipBadge}</span>
              )}
              {project.status === 'production' && (
                <span class="badge-prod">{t.projects.prodBadge}</span>
              )}
            </div>
            <a href={project.github} target="_blank" class="github-link" aria-label="GitHub">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </a>
          </div>

          <h3>{project.name}</h3>
          <p class="description">{project.description}</p>

          <div class="metrics">
            {project.metrics.map(m => (
              <div class="metric">
                <span class="metric-value">{m.value}</span>
                <span class="metric-label">{m.label}</span>
              </div>
            ))}
          </div>

          <div class="tags">
            {project.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const tabs = document.querySelectorAll('.tab');
    const cards = document.querySelectorAll('.card[data-category]');

    function filterProjects(tab) {
      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (tab === 'todos' || tab === 'all') {
          card.style.display = 'flex';
        } else {
          card.style.display = category === tab ? 'flex' : 'none';
        }
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', function () {
        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        filterProjects(this.getAttribute('data-tab').toLowerCase());
      });
    });
  });
</script>

<style>
  section {
    padding: 6rem 2rem;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header { margin-bottom: 2.5rem; }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--blue);
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
  }

  h2::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background: var(--blue);
    margin-top: 0.5rem;
  }

  .tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-muted);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    margin-bottom: -1px;
  }

  .tab:hover { color: var(--text); }

  .tab.active {
    color: var(--blue);
    border-bottom-color: var(--blue);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
    gap: 0.75rem;
  }

  .card:hover {
    border-color: var(--blue);
    transform: translateY(-2px);
  }

  .card.featured { border-color: rgba(88, 166, 255, 0.3); }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .badge-wip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    background: rgba(240, 165, 0, 0.1);
    color: var(--orange);
    border: 1px solid rgba(240, 165, 0, 0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .badge-prod {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    background: rgba(63, 185, 80, 0.1);
    color: var(--green);
    border: 1px solid rgba(63, 185, 80, 0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .github-link {
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .github-link:hover { color: var(--blue); }

  h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
  }

  .description {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex-grow: 1;
  }

  .metrics {
    display: flex;
    gap: 1.5rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .metric { display: flex; flex-direction: column; gap: 0.1rem; }

  .metric-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--blue);
    font-weight: 600;
  }

  .metric-label {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    background: rgba(88, 166, 255, 0.08);
    color: var(--green);
    border: 1px solid rgba(63, 185, 80, 0.2);
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
    .tabs { overflow-x: auto; }
  }

  @media (max-width: 480px) {
    section { padding: 4rem 1.25rem; }
    h2 { font-size: 1.6rem; }
  }
</style>